# ─── Supabase ────────────────────────────────────
# From: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (for Vercel serverless functions, NOT prefixed with VITE_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── PayFast ─────────────────────────────────────
# Mode: "sandbox" (default) or "live"
VITE_PAYFAST_MODE=sandbox

# PayFast Merchant Credentials
# Sandbox test creds (already hardcoded as fallback):
#   merchant_id = 10000100
#   merchant_key = 46f0cd694581a
# For production, use your REAL merchant credentials from PayFast dashboard
VITE_PAYFAST_MERCHANT_ID=10000100
VITE_PAYFAST_MERCHANT_KEY=46f0cd694581a

# PayFast Passphrase (optional - set in PayFast dashboard → Settings → Security)
# Used for MD5 signature verification on ITN notifications
PAYFAST_PASSPHRASE=

# ─── Site URL ────────────────────────────────────
# Your live domain — used for PayFast return/cancel/notify URLs
VITE_SITE_URL=https://nmct.co.za
